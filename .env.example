# Copy to .env for local dev or docker compose
# Docker Compose overrides DATABASE_URL and REDIS_URL to use service hostnames.

# Database
# DATABASE_URL — the APP connection. Use a NON-superuser, NON-BYPASSRLS role so
# Postgres RLS is actually enforced (a superuser silently bypasses every policy).
DATABASE_URL=postgresql://app_user:app_user@localhost:5432/marketing_agent
# DATABASE_ADMIN_URL — owner/superuser connection used ONLY for migrations
# (create tables, policies, grants). Never used to serve requests.
DATABASE_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/marketing_agent

# Redis
REDIS_URL=redis://localhost:6379

# LLM — OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
MODEL_FAST=openai/gpt-4o-mini
MODEL_BALANCED=openai/gpt-4o
MODEL_DEEP=anthropic/claude-sonnet-4

# Auth — WorkOS AuthKit (ADR-002). Every route resolves tenant from the SESSION.
# AUTH_PROVIDER selects the SessionProvider implementation:
#   dev    — trusts x-dev-user / x-dev-org headers (LOCAL DEV ONLY, never prod)
#   workos — verifies a WorkOS sealed session (requires the keys below)
# Defaults to 'workos' when WORKOS_API_KEY is set, else 'dev'.
AUTH_PROVIDER=dev
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=   # generate: openssl rand -base64 32

# Credential vault — KEK for envelope encryption (per-tenant DEKs) — generate: openssl rand -base64 32
CREDENTIALS_MASTER_KEY=

# Intel tools (design §12.3). Web search behind a provider seam; preference is
# Tavily -> Brave -> offline fixtures. Leave BOTH empty to run with fixtures
# (no key, no cost). IMPORTANT: keep the value empty with nothing after "=" —
# do NOT put an inline "# comment" on these lines. docker compose's env_file
# does not strip inline comments, so the comment text (em dash included) would
# become the key value and break outbound API calls.
#
# SearXNG: self-hosted, keyless metasearch (docker compose starts one for you).
# Preferred provider when set. Instance must have JSON output enabled.
SEARXNG_URL=http://searxng:8080
# Tavily: 1k free credits/mo, NO credit card required. Fallback if SEARXNG_URL unset.
TAVILY_API_KEY=
# Brave: $5/1k req; as of Feb 2026 requires a credit card (metered, no free tier).
BRAVE_API_KEY=
# SERPAPI_KEY intentionally omitted: $25/mo plan floor exceeds the ~$5-15 intel budget (ADR-003)

# Observability — Langfuse (MIT core; Cloud free tier). Tracing/evals only —
# per-tenant spend caps stay harness-enforced below, Langfuse cannot do them.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com

# App
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
# First-party origins allowed for credentialed CORS (comma-separated).
# Set to your deployed dashboard origin in prod. Never use a wildcard here.
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Optional image generation — Phase 3. "Nano Banana" is a nickname for Gemini
# image models, not a separate provider (ADR-003). SDK: @google/genai
IMAGE_GEN_PROVIDER=gemini
IMAGE_GEN_MODEL=gemini-3-pro-image   # ~$0.134/image @1K; 3.1-flash-image ~$0.067
# GOOGLE_AI_API_KEY=   # or GEMINI_API_KEY when image_gen_enabled

# Budget caps — harness-enforced hard stops (design §6.1)
DAILY_BUDGET_USD=10
MONTHLY_BUDGET_USD=50
MAX_RUN_COST_USD=2
