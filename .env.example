# Copy to .env for local dev or docker compose
# Docker Compose overrides DATABASE_URL and REDIS_URL to use service hostnames.

# Database (localhost when running npm run dev on host)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketing_agent

# Redis
REDIS_URL=redis://localhost:6379

# LLM — OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
MODEL_FAST=openai/gpt-4o-mini
MODEL_BALANCED=openai/gpt-4o
MODEL_DEEP=anthropic/claude-sonnet-4

# Credential vault — generate: openssl rand -base64 32
CREDENTIALS_MASTER_KEY=

# Optional intel tools
TAVILY_API_KEY=
SERPAPI_KEY=

# App
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Optional image generation (Nano Banana / Gemini) — Phase 3
IMAGE_GEN_PROVIDER=nano_banana
# GOOGLE_AI_API_KEY=   # or GEMINI_API_KEY when image_gen_enabled

# Ops alerts (Phase 9)
DAILY_BUDGET_USD=10
